# Secretos — NUNCA committeable
.env
.env.local
.env.vps

# Certs generados por gen-certs.sh
certs/
*.pem
*.key
*.crt
*.csr

# Backups locales (output de scripts/backup.sh — path específico, no cualquier carpeta llamada backups)
services/backups/
/backups/
*.sql.gz
*.sql.gz.gpg
*.dump
*.tar.gz

# Logs
*.log
logs/

# Volumenes mounts si alguien usa bind por path
data/

# Python
__pycache__/
*.pyc
.pytest_cache/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Config local del IDE/MCP — paths absolutos del home del dev (rompen
# `git pull` en otros clones) y pueden llevar API keys locales. Ver
# services/domain-backend/.gitignore para detalle + issue-29.4 (test
# que blinda que NUNCA vuelvan a trackearse).
opencode.json
opencode.json.backup-*
.mcp.json
.mcp.json.backup-*

# Tooling/dev (NO en repo, solo local)
.ai/
.claude/

# Artefactos temporales de playwright-mcp (screenshots, scripts de render)
.playwright-mcp/

# SDD specs (NO en repo, solo local)
openspec/
# excepción: el paquete Go internal/service/openspec SÍ va al repo
# (la regla openspec/ era para los árboles SDD exportados, no para el código).
!services/domain-mcp/internal/service/openspec/
!services/domain-mcp/internal/service/openspec/**
