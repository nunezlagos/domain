/dist/
/domain
/domain-mcp
*.exe
*.dll
*.so
*.dylib

# Build / Cache
/tmp/
/build/
*.test
*.out
coverage.out
coverage.html
profile.out

# Env / secrets — NUNCA committeable
.env
.env.local
.env.*.local
*.local
*.pem
*.key
*.crt
/secrets/
