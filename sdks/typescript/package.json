{
  "name": "@domain/sdk",
  "version": "0.1.0",
  "description": "Cliente TypeScript para Domain (memoria + orquestación AI agents)",
  "license": "proprietary",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "msw": "^2.7.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
