# ============================================================
# Domain — VPS env example
# ------------------------------------------------------------
# Copiar a .env y rellenar. NUNCA commitear .env. chmod 600 .env.
# Generar passwords con:
#   openssl rand -base64 48 | tr -d '/+=' | head -c 32
# ============================================================

# IP pública del VPS (si se accede por IP, no por dominio).
VPS_PUBLIC_IP=

# ------------------------------------------------------------
# Backend HTTP
# ------------------------------------------------------------
# Puerto interno del backend (Caddy lo proxyea en :80).
DOMAIN_HTTP_PORT=8000

# ------------------------------------------------------------
# Postgres
# ------------------------------------------------------------
PG_VERSION=pg16
PG_PORT=5432
POSTGRES_DB=domain
POSTGRES_USER=domain
# Superuser para migrations y operaciones admin.
POSTGRES_PASSWORD=CHANGE_ME
# app_user: rol NOBYPASSRLS que usa el backend para queries normales.
APP_USER_PASSWORD=CHANGE_ME
# app_admin: rol BYPASSRLS para auth/login (cruza orgs) + audit.
APP_ADMIN_PASSWORD=CHANGE_ME

# ------------------------------------------------------------
# Cifrado at-rest de campos (pgcrypto / pgp_sym)
# ------------------------------------------------------------
# Passphrase simetrica que cifra la API key en claro at-rest (auth_api_keys.
# key_ciphertext, mig 000168). La consumen TANTO domain-mcp (Go: Issue/Rotate)
# COMO domain-admin (Django: create/mostrar key). DEBE ser identica en ambos y
# estar presente o no se pueden emitir/mostrar keys nuevas. Generar con:
#   openssl rand -base64 48 | tr -d '/+=' | head -c 32
DOMAIN_FIELD_ENC_KEY=CHANGE_ME

# ------------------------------------------------------------
# MinIO (S3 compatible para attachments)
# ------------------------------------------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=domain-admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_DEFAULT_BUCKET=domain-attachments

# ------------------------------------------------------------
# Backups (REQ-66)
# ------------------------------------------------------------
# Passphrase para encriptar dumps con GPG (opcional; si no se usa GPG,
# el script actual no la consume — queda para fase 2).
BACKUP_GPG_PASSPHRASE=CHANGE_ME
# Días de retención del backup diario en /opt/services/backups/postgres/.
BACKUP_DAILY_RETAIN=7

# ------------------------------------------------------------
# Notificaciones operativas (alertas de cron, fallos, etc.)
# ------------------------------------------------------------
# Si NTFY_TOPIC está vacío, las notificaciones se omiten.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# ------------------------------------------------------------
# Grafana (REQ-70 — stack de monitoring opcional)
# ------------------------------------------------------------
# Credenciales del admin de Grafana en http://VPS_IP:3000.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ------------------------------------------------------------
# Embeddings (REQ-68)
# ------------------------------------------------------------
# Provider para vectores en observations/knowledge_docs.
#   noop   → búsqueda semántica desactivada (RAG cae a FTS). Default.
#   fake   → determinístico, solo para tests E2E.
# Si se agrega un provider real (Ollama, etc.), añadir las vars
# correspondientes acá.
DOMAIN_EMBEDDING_PROVIDER=noop

# ------------------------------------------------------------
# Query cache MCP (REQ-67)
# ------------------------------------------------------------
# El backend cachea respuestas READ de los tools MCP por 5-15s con
# invalidación por org en cada escritura. Para desactivarlo:
#   DOMAIN_DISABLE_CACHE=1
DOMAIN_DISABLE_CACHE=

# ------------------------------------------------------------
# Métricas Prometheus (REQ-70)
# ------------------------------------------------------------
# Si está activo, el backend expone /metrics en :9090 en la red
# interna de Docker para que Prometheus lo scrapee.
DOMAIN_METRICS_ENABLED=true
DOMAIN_METRICS_BIND=0.0.0.0
DOMAIN_METRICS_PORT=9090

# ------------------------------------------------------------
# CORS (cuando el dashboard llama al backend desde otro origen)
# ------------------------------------------------------------
# Lista separada por comas. Vacío = CORS desactivado (mismo origen).
DOMAIN_CORS_ORIGINS=

# ------------------------------------------------------------
# Frontend admin (REQ-74)
# ------------------------------------------------------------
# Base URL que usa el dashboard Angular para llamar a la API.
# Vacío = mismo origen (Caddy proxyea /api/* al backend). Solo cambiar
# si el dashboard se sirve desde un host separado.
API_URL=

# ------------------------------------------------------------
# SMTP (opcional — para alertas de uso y notificaciones futuras; NO se usa para OTP)
# ------------------------------------------------------------
# Si DOMAIN_SMTP_HOST está vacío, los emails NO se envían (NopMailer).
DOMAIN_SMTP_HOST=
DOMAIN_SMTP_PORT=587
DOMAIN_SMTP_AUTH=plain
DOMAIN_SMTP_USER=
DOMAIN_SMTP_PASSWORD=
DOMAIN_SMTP_TLS=true
DOMAIN_SMTP_FROM=no-reply@domain.local

# ------------------------------------------------------------
# Admin dashboard (HU-47.1 — login single-user)
# ------------------------------------------------------------
# Credenciales master del login del dashboard Django.
# Defaults en código: admin@admin.com / q1w2e3r4 (solo dev/demo).
# En producción, override acá. Si se rotan, re-correr install.sh
# o reiniciar el container domain-admin.
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=q1w2e3r4

# ------------------------------------------------------------
# Chat IA / LLM (HU-49.1 — provider MiniMax por default)
# ------------------------------------------------------------
# Provider LLM para el chat IA. Opciones:
#   minimax  → endpoint Anthropic-compatible, default.
#   anthropic → Anthropic directo (requiere ANTHROPIC_API_KEY).
LLM_PROVIDER=minimax

# MiniMax (default). Endpoint Anthropic-compatible.
# Token Plan API Key (empieza con sk-cp-).
MINIMAX_API_KEY=sk-cp-CHANGE_ME
# Modelo: MiniMax-M3 es el default (1M context, soporta extended thinking).
MINIMAX_MODEL=MiniMax-M3
# Region: international (api.minimax.io) | china (api.minimaxi.com)
MINIMAX_REGION=international
# Override del base URL (opcional, solo para proxy/self-hosted).
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# Anthropic (fallback). Solo si LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
