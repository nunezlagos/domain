# quiensabe.cl - Astro SSR reverse proxy (qs-app:4323, red domain_internal).
# Cert LE via HTTP-01 automatico (storage en /data/caddy, volume domain_caddy_data).
# SNI ordering: este block va ANTES del catch-all :80 para que quiensabe.cl
# no caiga al dashboard domain-admin. El puerto 443 ya esta publicado en
# docker-compose.yml (443:443).
quiensabe.cl, www.quiensabe.cl {
    reverse_proxy qs-app:4323
}

:80 {
  handle /api/* {
    reverse_proxy domain-mcp:8000
  }
  handle /mcp* {
    reverse_proxy domain-mcp:8000
  }
  handle /healthz {
    reverse_proxy domain-mcp:8000
  }
  # REQ-45: admin dashboard (Django placeholder en HU-45.1, vistas reales
  # en HU-45.2+). Si el container domain-admin no está corriendo, Caddy
  # responde 502 (no hay fallback).
  handle {
    reverse_proxy domain-admin:80
  }

  encode zstd gzip

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}
