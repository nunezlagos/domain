# ============================================================================
# domain-services — variables de entorno para Postgres + MinIO
#
# COPIAR a .env (cp .env.example .env) y RELLENAR antes de levantar.
# install.sh hace ese cp si no existe .env todavía.
#
# NUNCA committear .env. Está en .gitignore. Perms recomendadas: chmod 600 .env
# ============================================================================

# --- Identidad del VPS (necesario para certs self-signed con CN=IP) ---
# Si el script gen-certs.sh la detecta automáticamente, dejá vacío.
# Si no, poné la IP pública del VPS (ej. curl ifconfig.me).
VPS_PUBLIC_IP=

# --- Postgres ---
PG_VERSION=pg16
PG_PORT=5432
POSTGRES_DB=domain
POSTGRES_USER=domain
# Generá un password fuerte: openssl rand -base64 48 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=CHANGE_ME_pwgen_64_chars_random
# Usado por domain (app_user role) — privilegios NOBYPASSRLS según .claude/rules/connection-pools.md
APP_USER_PASSWORD=CHANGE_ME_pwgen_64_chars_random
# Usado por domain (app_admin role) — privilegios BYPASSRLS solo para auth/audit
APP_ADMIN_PASSWORD=CHANGE_ME_pwgen_64_chars_random

# --- MinIO ---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=domain-admin
# Generá: openssl rand -base64 48 | tr -d '/+=' | head -c 40
MINIO_ROOT_PASSWORD=CHANGE_ME_pwgen_64_chars_random
# Bucket inicial que MinIO crea al boot via mc en el entrypoint
MINIO_DEFAULT_BUCKET=domain-attachments

# --- Backups ---
# Passphrase para gpg --symmetric en pg_dump → cifrado at-rest
BACKUP_GPG_PASSPHRASE=CHANGE_ME_pwgen_64_chars_random
# Retención: cuántos backups conservar
BACKUP_DAILY_RETAIN=7
BACKUP_WEEKLY_RETAIN=4
BACKUP_MONTHLY_RETAIN=12

# --- Alerting (ntfy.sh) ---
# Topic privado para alerts. Cualquier string difícil de adivinar funciona.
# Ejemplo: domain-vps-alerts-7f3a9c
# Suscribirse en la app ntfy: https://ntfy.sh/<TOPIC>
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
