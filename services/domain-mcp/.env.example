# ============================================================
# Domain backend — env example para DESARROLLO LOCAL (sin Docker)
# ------------------------------------------------------------
# Este archivo es para correr `go run ./cmd/domain server` desde la
# máquina del dev contra servicios locales (postgres, mailpit, minio).
#
# En el VPS NO se usa este archivo — el backend toma sus env vars del
# bloque `environment:` del docker-compose.yml, que a su vez consume
# `services/.env`. Ver `services/.env.example`.
# ============================================================

# ------------------------------------------------------------
# Postgres
# ------------------------------------------------------------
DOMAIN_DB_USER=domain
DOMAIN_DB_PASSWORD=domain
DOMAIN_DB_NAME=domain
DOMAIN_DATABASE_URL=postgres://domain:domain@localhost:5432/domain?sslmode=disable
# Pool BYPASSRLS para auth/login (cruza orgs). En dev local apunta al
# mismo postgres pero con el rol app_admin.
DOMAIN_DATABASE_AUTH_URL=postgres://domain:domain@localhost:5432/domain?sslmode=disable
HOST_POSTGRES_PORT=5432

# Cifrado at-rest de campos (pgcrypto/pgp_sym). Passphrase simetrica que cifra
# la API key en claro (auth_api_keys.key_ciphertext, mig 000168). DEBE ser
# IDENTICA a la de domain-admin (mismo nombre, mismo valor) o las keys cifradas
# por un servicio no se podran descifrar/mostrar en el otro. Si esta vacia,
# Issue/Rotate fallan (no se escribe la key en claro como fallback).
DOMAIN_FIELD_ENC_KEY=CHANGE_ME

# ------------------------------------------------------------
# S3 / MinIO (storage de attachments)
# ------------------------------------------------------------
DOMAIN_S3_ENDPOINT=http://localhost:9000
DOMAIN_S3_REGION=us-east-1
DOMAIN_S3_BUCKET=domain-assets
DOMAIN_S3_ACCESS_KEY=domain
DOMAIN_S3_SECRET_KEY=domainsecret
DOMAIN_S3_USE_PATH_STYLE=true
HOST_MINIO_PORT=9000
HOST_MINIO_CONSOLE_PORT=9001

# ------------------------------------------------------------
# Adminer (UI de DB en dev)
# ------------------------------------------------------------
HOST_ADMINER_PORT=8080

# ------------------------------------------------------------
# Mailpit / SMTP (email para alertas de uso y notificaciones; NO se usa para OTP)
# ------------------------------------------------------------
DOMAIN_SMTP_HOST=localhost
DOMAIN_SMTP_PORT=1025
DOMAIN_SMTP_AUTH=none
DOMAIN_SMTP_USER=
DOMAIN_SMTP_PASSWORD=
DOMAIN_SMTP_TLS=false
DOMAIN_SMTP_FROM=no-reply@domain.local
HOST_SMTP_PORT=1025
HOST_MAILPIT_UI_PORT=8025

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
DOMAIN_HTTP_BIND=127.0.0.1
DOMAIN_HTTP_PORT=8000
DOMAIN_HTTP_READ_TIMEOUT_SECONDS=30
DOMAIN_HTTP_WRITE_TIMEOUT_SECONDS=30

# ------------------------------------------------------------
# CORS (frontend en otro puerto durante dev)
# ------------------------------------------------------------
# Permite que el dev server de Angular en :4200 llame al backend en :8000.
DOMAIN_CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
DOMAIN_LOG_LEVEL=info
DOMAIN_LOG_FORMAT=text
DOMAIN_LOG_OUTPUT=stdout
DOMAIN_LOG_ADD_SOURCE=false

# ------------------------------------------------------------
# Métricas / Tracing — apagados por default en dev
# ------------------------------------------------------------
DOMAIN_METRICS_ENABLED=false
DOMAIN_METRICS_BIND=127.0.0.1
DOMAIN_METRICS_PORT=9090

DOMAIN_OTEL_ENABLED=false
DOMAIN_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
DOMAIN_OTEL_EXPORTER_OTLP_PROTOCOL=grpc
DOMAIN_OTEL_SAMPLE_RATIO=1.0
DOMAIN_OTEL_SERVICE_NAME=domain-mcp

# ------------------------------------------------------------
# Embeddings (REQ-68)
# ------------------------------------------------------------
# Provider de vectores. Valores soportados:
#   noop   → desactiva búsqueda semántica. Default.
#   fake   → vector determinístico hash-based (para tests reproducibles).
#   ollama → local, sin API key (servicio services/ollama). RECOMENDADO.
#   openai → requiere DOMAIN_OPENAI_API_KEY.
#   voyage → requiere DOMAIN_VOYAGE_API_KEY.
#
# El esquema pgvector es vector(1024) desde la migración 000275. El server mide
# la dimensión real al arrancar y degrada a noop si no coincide (DOMAINSERV-80
# H2). bge-m3 = 1024 y multilingüe; nomic-embed-text (768) y
# text-embedding-3-small (1536) NO entran sin migrar el esquema.
DOMAIN_EMBEDDING_PROVIDER=noop
DOMAIN_OLLAMA_URL=http://ollama:11434
DOMAIN_OLLAMA_EMBED_MODEL=bge-m3

# ------------------------------------------------------------
# Query cache MCP (REQ-67)
# ------------------------------------------------------------
# Para apagar el cache LRU de los tools READ:
#   DOMAIN_DISABLE_CACHE=1
DOMAIN_DISABLE_CACHE=

# ------------------------------------------------------------
# Seeders
# ------------------------------------------------------------
DOMAIN_SEED_ON_BOOT=true
DOMAIN_ENV=dev
